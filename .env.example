# Copy to .env (or let bootstrap.sh do it for you).
# Loaded by docker-compose, Foreman/Overmind (Procfile.dev), and the Rails app.
#
# Ports are auto-allocated by bin/allocate-ports → .ports.env.
# Anything below referring to ${BACKEND_PORT} / ${POSTGRES_PORT} / etc.
# will be substituted on first run.

# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_development
# Host port for Postgres — substituted from .ports.env at bootstrap.
POSTGRES_PORT=5433
DATABASE_URL=postgres://postgres:postgres@localhost:5433/app_development

# === Backend ===
RAILS_ENV=development
RAILS_MASTER_KEY=          # generated by Rails on first boot
JWT_SECRET=please-change-me-in-production
JWT_EXPIRES_IN_HOURS=24
BACKEND_PORT=3000
CORS_ORIGINS=http://localhost:5173

# === Frontend ===
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3000

# === Mail (Mailpit in dev) ===
SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_PORT=1025

# === Sentry (optional) ===
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
