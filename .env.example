# Copy to .env and fill in.
# Loaded by docker-compose and Foreman (Procfile.dev).

# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app_development

# === Backend ===
RAILS_ENV=development
RAILS_MASTER_KEY=          # generated by Rails on first boot
JWT_SECRET=please-change-me-in-production
JWT_EXPIRES_IN_HOURS=24
CORS_ORIGINS=http://localhost:5173

# === Frontend ===
VITE_API_BASE_URL=http://localhost:3000

# === Mail (Mailhog in dev) ===
SMTP_HOST=localhost
SMTP_PORT=1025

# === Sentry (optional) ===
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
