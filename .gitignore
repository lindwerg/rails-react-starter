# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Env
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
log/
tmp/

# Backend (Rails)
backend/log/
backend/tmp/
backend/.bundle/
backend/vendor/bundle/
backend/storage/
backend/coverage/
backend/public/assets/
backend/public/packs/
backend/.byebug_history
backend/.rspec_status
backend/.rubocop_cache/
backend/swagger/v1/swagger.yaml.tmp
backend/db/*.sqlite3
backend/db/*.sqlite3-journal

# Frontend (Node)
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.turbo/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/.eslintcache
frontend/storybook-static/
frontend/*.tsbuildinfo

# Lockfile policy: keep them committed (do NOT ignore)
# - backend/Gemfile.lock
# - frontend/pnpm-lock.yaml

# Claude
.claude/.local/
.claude/cache/
.claude/settings.local.json
.claude/.last-test-status
.claude/.last-packwerk-status
.claude/.session-state
.claude/scheduled_tasks.lock
.mcp.env
.playwright-mcp/

# Kamal
.kamal/secrets
config/credentials/*.key
backend/config/master.key
# credentials.yml.enc is encrypted with master.key — each clone of the
# template generates its own pair via `bootstrap.sh`, so the template repo
# itself must not ship a pre-generated one (consumers couldn't decrypt it).
backend/config/credentials.yml.enc

# Misc
.cache/
*.pid

# Bootstrap runtime artifacts (auto-allocated per-machine)
.ports.env
.template-renamed
docker-compose.override.yml
