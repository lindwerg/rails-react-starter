#!/usr/bin/env bash
# bin/allocate-ports — find free TCP ports and persist them to .ports.env.
#
# Idempotent: if .ports.env already exists, it is reused as-is unless --force.
# Sourceable: when sourced, only defines free_port() / load_ports() helpers
#             without doing any allocation.
#
# Usage:
#   bin/allocate-ports                # allocate (no-op if .ports.env exists)
#   bin/allocate-ports --force        # re-pick all ports from defaults
#   bin/allocate-ports --print        # print current allocation, do not write
#   source bin/allocate-ports         # use as library (defines free_port, load_ports)
#
# Allocated keys (host ports — what your laptop sees):
#   BACKEND_PORT       — Rails API           (default 3000)
#   FRONTEND_PORT      — Vite dev server     (default 5173)
#   POSTGRES_PORT      — Postgres host port  (default 5433)
#   MAILPIT_SMTP_PORT  — Mailpit SMTP        (default 1025)
#   MAILPIT_UI_PORT    — Mailpit web UI      (default 8025)
#
# Compatible with bash 3.2 (the default macOS shell).

set -uo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PORTS_FILE="${REPO_ROOT}/.ports.env"

# ──────────────────────────────────────────────────────────────────────
# free_port DESIRED [MAX_HOPS]
#   Echo the first unbound TCP port at or above DESIRED.
# ──────────────────────────────────────────────────────────────────────
free_port() {
  local p="${1:?free_port: desired port required}"
  local max_hops="${2:-200}"
  local hops=0
  while [ "$hops" -lt "$max_hops" ]; do
    if ! _port_in_use "$p"; then
      echo "$p"
      return 0
    fi
    p=$((p + 1))
    hops=$((hops + 1))
  done
  echo "free_port: no free port found in [${1}, ${1}+${max_hops}]" >&2
  return 1
}

_port_in_use() {
  local p="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$p" -sTCP:LISTEN >/dev/null 2>&1 && return 0
  fi
  if command -v nc >/dev/null 2>&1; then
    nc -z 127.0.0.1 "$p" >/dev/null 2>&1 && return 0
  fi
  return 1
}

# ──────────────────────────────────────────────────────────────────────
# load_ports
#   Source .ports.env and export every variable defined there.
# ──────────────────────────────────────────────────────────────────────
load_ports() {
  if [ -f "${PORTS_FILE}" ]; then
    set -a
    # shellcheck disable=SC1090
    . "${PORTS_FILE}"
    set +a
  fi
}

# ──────────────────────────────────────────────────────────────────────
# Stop here if sourced.
#   ${BASH_SOURCE[0]} != $0 means we were sourced.
# ──────────────────────────────────────────────────────────────────────
if [ "${BASH_SOURCE[0]}" != "${0}" ]; then
  return 0 2>/dev/null || true
fi

# ──────────────────────────────────────────────────────────────────────
# Standalone entry point.
# ──────────────────────────────────────────────────────────────────────
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
NC=$'\033[0m'

force=0
print_only=0
for arg in "$@"; do
  case "$arg" in
    --force)  force=1 ;;
    --print)  print_only=1 ;;
    -h|--help)
      sed -n '2,/^$/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "Unknown flag: $arg" >&2; exit 2 ;;
  esac
done

if [ "$print_only" -eq 1 ]; then
  if [ -f "${PORTS_FILE}" ]; then cat "${PORTS_FILE}"; else echo "(no .ports.env yet)"; fi
  exit 0
fi

if [ "$force" -eq 0 ] && [ -f "${PORTS_FILE}" ]; then
  echo "  ✓ .ports.env already exists (use --force to re-allocate)"
  exit 0
fi

# Two parallel arrays — bash 3.2 has no associative arrays.
PORT_KEYS=(BACKEND_PORT FRONTEND_PORT POSTGRES_PORT MAILPIT_SMTP_PORT MAILPIT_UI_PORT)
PORT_DEFS=(3000          5173          5433          1025              8025)

USED_LIST=" "
ALLOC_VALS=""

i=0
for key in "${PORT_KEYS[@]}"; do
  default="${PORT_DEFS[$i]}"
  desired="$default"
  # Defaults shouldn't overlap, but be defensive in case someone edits the table.
  while echo "${USED_LIST}" | grep -q " ${desired} "; do
    desired=$((desired + 1))
  done
  picked="$(free_port "$desired")"
  USED_LIST="${USED_LIST}${picked} "
  ALLOC_VALS="${ALLOC_VALS}${key}=${picked}\n"
  if [ "$picked" != "$default" ]; then
    printf "  ${YELLOW}⚠${NC} %-18s default %s busy → using %s\n" "$key" "$default" "$picked"
  else
    printf "  ${GREEN}✓${NC} %-18s %s\n" "$key" "$picked"
  fi
  i=$((i + 1))
done

{
  echo "# Auto-generated by bin/allocate-ports — do not edit by hand."
  echo "# Re-run \`bin/allocate-ports --force\` to re-pick."
  echo "# Sourced by bootstrap.sh, bin/dev, docker compose (via env)."
  printf '%b' "${ALLOC_VALS}"
} > "${PORTS_FILE}"

echo ""
echo "  Wrote ${PORTS_FILE}"
